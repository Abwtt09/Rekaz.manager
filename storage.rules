rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ============================================
    // COMPANY LOGO UPLOADS
    // companies/{companyId}/logo/{fileName}
    // ============================================
    match /companies/{companyId}/logo/{fileName} {
      // Any authenticated user can read company logos
      allow read: if request.auth != null;

      // Only authenticated users can upload logos
      // Validates: file < 5MB, must be image type
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // ============================================
    // COMPANY FILES (future use)
    // companies/{companyId}/files/{allPaths=**}
    // ============================================
    match /companies/{companyId}/files/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024;
    }

    // Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
